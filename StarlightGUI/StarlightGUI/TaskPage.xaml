<Page
    x:Class="StarlightGUI.TaskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:XamlToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:StarlightGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource WindowBackgroundBrush}"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid>
        <Grid Padding="20,10,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  固定标题栏区域  -->
            <Grid
                Grid.Row="0"
                Padding="0,0,0,5"
                Background="{StaticResource WindowBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="TaskTitleUid"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="任务管理器" />

                <TextBlock
                    x:Name="ProcessCountText"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    Text="正在加载..." />

                <CommandBar
                    Grid.Column="3"
                    HorizontalAlignment="Right"
                    DefaultLabelPosition="Right">
                    <AppBarButton
                        x:Name="RefreshProcessListButton"
                        Click="RefreshProcessListButton_Click"
                        Label="刷新">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xe72c;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        x:Name="TaskRunUid"
                        Click="CreateProcessButton_Click"
                        Label="运行进程">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xefda;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        x:Name="TerminateProcessButton"
                        Click="TerminateProcessButton_Click"
                        IsEnabled="False"
                        Label="结束进程">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xe733;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <AutoSuggestBox
                    x:Name="ProcessSearchBox"
                    Grid.Column="4"
                    Width="300"
                    Height="32"
                    HorizontalAlignment="Right"
                    essential:AutoSuggestBoxHelper.AcrylicWorkaround="True"
                    PlaceholderText="搜索进程..."
                    QueryIcon="Find"
                    QuerySubmitted="ProcessSearchBox_QuerySubmitted"
                    SuggestionChosen="ProcessSearchBox_SuggestionChosen"
                    TextChanged="ProcessSearchBox_TextChanged" />
            </Grid>

            <Border
                Grid.Row="1"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="5,5,0,0">
                <Grid x:Name="HeaderColumnsGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="NameHeaderButton"
                        Grid.Column="0"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        Click="ColumnHeader_Click"
                        Content="进程"
                        CornerRadius="0"
                        Tag="Name" />
                    <Button
                        x:Name="EProcessHeaderButton"
                        Grid.Column="1"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Click="ColumnHeader_Click"
                        Content="EPROCESS"
                        CornerRadius="0"
                        Tag="EProcess" />
                    <Button
                        x:Name="CpuHeaderButton"
                        Grid.Column="2"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Click="ColumnHeader_Click"
                        Content="CPU"
                        CornerRadius="0"
                        Tag="CpuUsage" />
                    <Button
                        x:Name="MemoryHeaderButton"
                        Grid.Column="3"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Click="ColumnHeader_Click"
                        Content="内存"
                        CornerRadius="0"
                        Tag="MemoryUsage" />
                    <Button
                        x:Name="IdHeaderButton"
                        Grid.Column="4"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Click="ColumnHeader_Click"
                        Content="PID"
                        CornerRadius="0"
                        Tag="Id" />

                    <ct:GridSplitter
                        Grid.Column="0"
                        Width="9"
                        Margin="0,0,-5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Opacity="0"
                        ResizeBehavior="BasedOnAlignment"
                        ResizeDirection="Columns" />
                    <ct:GridSplitter
                        Grid.Column="1"
                        Width="9"
                        Margin="0,0,-5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Opacity="0"
                        ResizeBehavior="BasedOnAlignment"
                        ResizeDirection="Columns" />
                    <ct:GridSplitter
                        Grid.Column="2"
                        Width="9"
                        Margin="0,0,-5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Opacity="0"
                        ResizeBehavior="BasedOnAlignment"
                        ResizeDirection="Columns" />
                    <ct:GridSplitter
                        Grid.Column="3"
                        Width="9"
                        Margin="0,0,-5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Opacity="0"
                        ResizeBehavior="BasedOnAlignment"
                        ResizeDirection="Columns" />
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5">
                <Grid x:Name="BodyColumnsGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <ProgressRing
                        x:Name="LoadingRing"
                        Grid.ColumnSpan="6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="False" />

                    <ListView
                        x:Name="ProcessListView"
                        Grid.ColumnSpan="6"
                        Background="Transparent"
                        ContainerContentChanging="ProcessListView_ContainerContentChanging"
                        ItemContainerStyle="{StaticResource ListViewItemStyle}"
                        RightTapped="ProcessListView_RightTapped"
                        SelectionChanged="ProcessListView_SelectionChanged">

                        <!--  进程数据  -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="ProcessRowGrid" Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <!--  进程图标  -->
                                    <Image
                                        Grid.Column="0"
                                        Width="16"
                                        Height="16"
                                        Margin="16,0,12,0"
                                        VerticalAlignment="Center"
                                        Source="{Binding Icon}" />

                                    <!--  进程名  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip
                                                    essential:ToolTipHelper.AcrylicWorkaround="True"
                                                    Content="{Binding Name}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                            Text="{Binding Description}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip
                                                    essential:ToolTipHelper.AcrylicWorkaround="True"
                                                    Content="{Binding Description}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  EPROCESS  -->
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding EProcess}" />

                                    <!--  CPU  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding CpuUsage}" />

                                    <!--  内存使用  -->
                                    <TextBlock
                                        Grid.Column="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding MemoryUsage}" />

                                    <!--  进程ID  -->
                                    <TextBlock
                                        Grid.Column="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding Id}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>
        <StackPanel
            x:Name="InfoBarPanel"
            Margin="0,10,10,0"
            HorizontalAlignment="Right" />
    </Grid>
</Page>



