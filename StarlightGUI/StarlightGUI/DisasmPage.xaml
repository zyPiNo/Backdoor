<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StarlightGUI.DisasmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:StarlightGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid>
        <Grid Padding="20,10,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  固定标题栏区域  -->
            <Grid
                Grid.Row="0"
                Padding="0,0,0,5"
                Background="{StaticResource WindowBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="DisasmTitleUid"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="内存反汇编" />

                <ComboBox
                    x:Name="ModeComboBox"
                    Grid.Column="2"
                    essential:ComboBoxHelper.AcrylicWorkaround="True"
                    ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                    SelectedIndex="0">
                    <ComboBoxItem x:Name="DisasmModeReadUid" Content="读取" />
                    <ComboBoxItem x:Name="DisasmModeReadDisasmUid" Content="读取 + 反汇编" />
                    <ComboBoxItem x:Name="DisasmModeWriteUid" Content="写入" />
                </ComboBox>

                <Button
                    Grid.Column="3"
                    Margin="10,0,0,0"
                    Click="Button_Click"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xe945;" />
                        <TextBlock
                            x:Name="DisasmExecuteUid"
                            Margin="5,0,0,0"
                            Text="执行" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid
                Grid.Row="1"
                Padding="0,0,0,5"
                Background="{StaticResource WindowBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.6*" />
                    <ColumnDefinition Width="0.2*" />
                    <ColumnDefinition Width="0.2*" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="AddressBox"
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    Header="地址"
                    Text="0xFFFFF00000000000" />

                <TextBox
                    x:Name="SizeBox"
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    Header="大小"
                    Text="256" />

                <TextBox
                    x:Name="ValueBox"
                    Grid.Column="2"
                    Margin="0,0,0,0"
                    Header="值"
                    Text="0" />
            </Grid>

            <essential:RevealFocusPanel x:Name="RevealFocusPanel" Grid.Row="2">
                <Button
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    essential:RevealFocusPanel.AttachToPanel="{x:Bind RevealFocusPanel}">
                    <ScrollView>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="HexText"
                                Grid.Column="0"
                                MinWidth="100"
                                FontFamily="Consolas"
                                IsTextSelectionEnabled="True"
                                Text="无"
                                TextWrapping="Wrap" />
                            <Border
                                Grid.Column="1"
                                Width="1"
                                Margin="10,0,10,0"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource AppSeparatorBrush}" />
                            <TextBlock
                                x:Name="CharText"
                                Grid.Column="2"
                                MinWidth="100"
                                FontFamily="Consolas"
                                IsTextSelectionEnabled="True"
                                Text="无"
                                TextWrapping="Wrap" />
                        </Grid>
                    </ScrollView>
                </Button>
            </essential:RevealFocusPanel>
        </Grid>
    </Grid>
</Page>
