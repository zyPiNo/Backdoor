                CornerRadius="5,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="HALTableNameModuleHeaderButton"
                        Grid.Column="0"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        Content="名称/模块"
                        CornerRadius="0" />
                    <Button
                        x:Name="HALTableAddressHeaderButton"
                        Grid.Column="1"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="地址"
                        CornerRadius="0" />
                </Grid>
            </Border>
            <Border
                Grid.Row="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <ListView
                        x:Name="HALTableListView"
                        Grid.ColumnSpan="2"
                        Background="Transparent"
                        ItemContainerStyle="{StaticResource ListViewItemStyle}"
                        RightTapped="HALTableListView_RightTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>

                                    <!--  名称/模块  -->
                                    <StackPanel
                                        Grid.Column="0"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                            Text="{Binding String1}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding String1}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                            Text="{Binding String2}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding String2}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  地址  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String3}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Page>








