<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StarlightGUI.MonitorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource WindowBackgroundBrush}"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid Padding="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  固定标题栏区域  -->
        <Grid
            Grid.Row="0"
            Padding="0,0,0,5"
            Background="{StaticResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ScrollView
                Grid.Column="0"
                ContentOrientation="Horizontal"
                HorizontalScrollBarVisibility="Auto"
                HorizontalScrollMode="Enabled"
                VerticalScrollMode="Disabled">
                <essential:Segmented
                    x:Name="MainSegmented"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    SelectionChanged="MainSegmented_SelectionChanged">
                    <essential:SegmentedItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xf0b2;" />
                            <TextBlock x:Name="MonitorSegObjectUid" Text="对象" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="CallbackSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe77e;" />
                            <TextBlock x:Name="MonitorSegCallbackUid" Text="回调/消息" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="MiniFilterSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe7e3;" />
                            <TextBlock x:Name="MonitorSegMiniFilterUid" Text="微过滤驱动" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="SSDTSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xf0b9;" />
                            <TextBlock x:Name="MonitorSegSSDTUid" Text="SSDT" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="SSSDTSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe727;" />
                            <TextBlock x:Name="MonitorSegSSSDTUid" Text="Shadow SSDT" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="IoTimerSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe916;" />
                            <TextBlock x:Name="MonitorSegIOTimerUid" Text="I/O 定时器" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="IDTSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe950;" />
                            <TextBlock x:Name="MonitorSegIDTUid" Text="中断描述符表" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="GDTSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe964;" />
                            <TextBlock x:Name="MonitorSegGDTUid" Text="全局描述符表" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="PiDDBSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xf0e3;" />
                            <TextBlock x:Name="MonitorSegPiDDBUid" Text="PiDDB 缓存表" />
                        </StackPanel>
                    </essential:SegmentedItem>
                    <essential:SegmentedItem x:Name="HALTableSegmentedItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xf590;" />
                            <TextBlock x:Name="MonitorSegHALTableUid" Text="HAL 分发表" />
                        </StackPanel>
                    </essential:SegmentedItem>
                </essential:Segmented>
            </ScrollView>
            <CommandBar
                Grid.Column="2"
                HorizontalAlignment="Right"
                DefaultLabelPosition="Right">
                <AppBarButton
                    x:Name="RefreshButton"
                    Click="RefreshButton_Click"
                    Label="刷新">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xe72c;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Name="CallbackTypeButton"
                    Label="类型"
                    Visibility="Collapsed">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xe71c;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Name="HALTableButton"
                    Label="HAL"
                    Visibility="Collapsed">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xe71c;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="3"
                Width="300"
                Height="32"
                HorizontalAlignment="Right"
                essential:AutoSuggestBoxHelper.AcrylicWorkaround="True"
                PlaceholderText="搜索..."
                QueryIcon="Find"
                QuerySubmitted="SearchBox_QuerySubmitted"
                SuggestionChosen="SearchBox_SuggestionChosen"
                TextChanged="SearchBox_TextChanged" />
        </Grid>

        <ProgressRing
            x:Name="LoadingRing"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="False" />

        <TextBlock
            x:Name="DefaultText"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Text="选择一个板块。"
            Visibility="Visible" />

        <Grid
            x:Name="ObjectGrid"
            Grid.Row="1"
            Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="5,0,0,5">
                <ScrollViewer
                    MaxWidth="150"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled">
                    <essential:RevealFocusPanel x:Name="RevealFocusPanel2">
                        <essential:Segmented
                            x:Name="ObjectTreeView"
                            VerticalAlignment="Top"
                            essential:RevealFocusPanel.AttachToPanel="{x:Bind RevealFocusPanel2}"
                            BorderThickness="0"
                            CornerRadius="0"
                            SelectionChanged="ObjectTreeView_SelectionChanged"
                            Style="{StaticResource ButtonSegmentedStyle}">
                            <essential:Segmented.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </essential:Segmented.ItemsPanel>
                        </essential:Segmented>
                    </essential:RevealFocusPanel>
                </ScrollViewer>
            </Border>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border
                    Grid.Row="0"
                    BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="0,1,1,1"
                    CornerRadius="0,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <Button
                            x:Name="ObjectNameHeaderButton"
                            Grid.Column="0"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            Content="名称"
                            CornerRadius="0" />
                        <Button
                            x:Name="ObjectTypeHeaderButton"
                            Grid.Column="1"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                            BorderThickness="1,0,0,0"
                            Content="类型"
                            CornerRadius="0" />
                    </Grid>
                </Border>
                <Border
                    Grid.Row="1"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="0,0,1,1"
                    CornerRadius="0,0,5,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <ListView
                            x:Name="ObjectListView"
                            Grid.ColumnSpan="2"
                            Background="Transparent"
                            ItemContainerStyle="{StaticResource ListViewItemStyle}"
                            RightTapped="ObjectListView_RightTapped">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="50">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>

                                        <!--  名称  -->
                                        <StackPanel
                                            Grid.Column="0"
                                            Margin="16,0,0,0"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding Name}" />
                                                </ToolTipService.ToolTip>
                                            </TextBlock>
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                Text="{Binding Path}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding Path}" />
                                                </ToolTipService.ToolTip>
                                            </TextBlock>
                                        </StackPanel>

                                        <!--  类型  -->
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                            Text="{Binding Type}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Border
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                            BorderThickness="1,0,0,0"
                            IsHitTestVisible="False" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:Name="CallbackGrid"
            Grid.Row="1"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="5,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CallbackHeaderColumn0" Width="*" />
                        <ColumnDefinition x:Name="CallbackHeaderColumn1" Width="150" />
                        <ColumnDefinition x:Name="CallbackHeaderColumn2" Width="150" />
                        <ColumnDefinition x:Name="CallbackHeaderColumn3" Width="150" />
                        <ColumnDefinition x:Name="CallbackHeaderColumn4" Width="150" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="CallbackTypeModuleHeaderButton"
                        Grid.Column="0"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        Content="类型/模块"
                        CornerRadius="0" />
                    <Button
                        x:Name="CallbackEntryHeaderButton"
                        Grid.Column="1"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="入口"
                        CornerRadius="0" />
                    <Button
                        x:Name="CallbackHandleHeaderButton"
                        Grid.Column="2"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="句柄"
                        CornerRadius="0" />
                    <Button
                        x:Name="CallbackAddress3HeaderButton"
                        Grid.Column="3"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="Address3"
                        CornerRadius="0" />
                    <Button
                        x:Name="CallbackAddress4HeaderButton"
                        Grid.Column="4"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="Address4"
                        CornerRadius="0" />
                </Grid>
            </Border>
            <Border
                Grid.Row="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CallbackBodyColumn0" Width="*" />
                        <ColumnDefinition x:Name="CallbackBodyColumn1" Width="150" />
                        <ColumnDefinition x:Name="CallbackBodyColumn2" Width="150" />
                        <ColumnDefinition x:Name="CallbackBodyColumn3" Width="150" />
                        <ColumnDefinition x:Name="CallbackBodyColumn4" Width="150" />
                    </Grid.ColumnDefinitions>

                    <ListView
                        x:Name="CallbackListView"
                        Grid.ColumnSpan="5"
                        Background="Transparent"
                        ItemContainerStyle="{StaticResource ListViewItemStyle}"
                        RightTapped="CallbackListView_RightTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>

                                    <!--  类型/模块  -->
                                    <StackPanel
                                        Grid.Column="0"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                            Text="{Binding String1}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding String1}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                            Text="{Binding String2}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding String2}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  入口  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String3}" />

                                    <!--  句柄  -->
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String4}" />

                                    <!--  Address3  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String5}" />

                                    <!--  Address4  -->
                                    <TextBlock
                                        Grid.Column="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String6}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="MiniFilterGrid"
            Grid.Row="1"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="5,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="MiniFilterIRPModuleHeaderButton"
                        Grid.Column="0"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        Content="IRP/模块"
                        CornerRadius="0" />
                    <Button
                        x:Name="MiniFilterBaseHeaderButton"
                        Grid.Column="1"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="基址"
                        CornerRadius="0" />
                    <Button
                        x:Name="MiniFilterPreFilterHeaderButton"
                        Grid.Column="2"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="PreFilter"
                        CornerRadius="0" />
                    <Button
                        x:Name="MiniFilterPostFilterHeaderButton"
                        Grid.Column="3"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="PostFilter"
                        CornerRadius="0" />
                </Grid>
            </Border>
            <Border
                Grid.Row="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <ListView
                        x:Name="MiniFilterListView"
                        Grid.ColumnSpan="4"
                        Background="Transparent"
                        ItemContainerStyle="{StaticResource ListViewItemStyle}"
                        RightTapped="MiniFilterListView_RightTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>

                                    <!--  IRP/模块  -->
                                    <StackPanel
                                        Grid.Column="0"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                            Text="{Binding String1}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding String1}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                            Text="{Binding String2}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="{Binding String2}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  基址  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String3}" />

                                    <!--  PreFilter  -->
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String4}" />

                                    <!--  PostFilter  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding String5}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="SSDTGrid"
            Grid.Row="1"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="5,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="SSDTNameModuleHeaderButton"
                        Grid.Column="0"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        Content="名称/模块"
                        CornerRadius="0" />
                    <Button
                        x:Name="SSDTAddressHeaderButton"
                        Grid.Column="1"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Content="地址"
                        CornerRadius="0" />
                </Grid>
            </Border>
            <Border
                Grid.Row="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <ListView
                        x:Name="SSDTListView"
                        Grid.ColumnSpan="5"
                        Background="Transparent"
                        ItemContainerStyle="{StaticResource ListViewItemStyle}"
                        RightTapped="SSDTListView_RightTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>

                                    <!--  名称/模块  -->
                                    <StackPanel
                                        Grid.Column="0"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                            Text="{Binding String1}"
                                            TextTrimming="CharacterEllipsis"
