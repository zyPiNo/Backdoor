<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="StarlightGUI.UpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:StarlightGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.TitleTemplate>
        <DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon
                    Margin="0,5,0,0"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="30"
                    Glyph="&#xecc5;" />
                <TextBlock VerticalAlignment="Center" Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <Grid>
        <StackPanel
            x:Name="UpdateStackPanel"
            Margin="0,0,0,10"
            Visibility="Collapsed">
            <TextBlock x:Name="NewVersionAvailableText" />
            <TextBlock>
                <Run x:Name="CurrentVersionLabelRun" />
                <Run Text="{StaticResource Version}" />
            </TextBlock>
            <TextBlock Margin="0,0,0,10">
                <Run x:Name="LatestVersionLabelRun" />
                <Run x:Name="LatestVersionText" />
            </TextBlock>
            <TextBlock x:Name="UpdateDescriptionText" />
            <TextBlock
                x:Name="UpdateTipText"
                Margin="0,0,0,10"
                FontSize="12"
                Foreground="{ThemeResource AppSecondaryTextBrush}" />
            <Border
                Height="1"
                Margin="0,0,0,10"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource AppSeparatorBrush}" />
            <TextBlock x:Name="QuarkCodeText" />
            <TextBlock x:Name="NoDirectLinkText" />
        </StackPanel>
        <StackPanel
            x:Name="AnnouncementStackPanel"
            Margin="0,0,0,10"
            Visibility="Collapsed">
            <TextBlock
                x:Name="AnnouncementText"
                Margin="0,0,0,10"
                TextWrapping="WrapWholeWords" />
            <TextBlock
                Margin="0,0,0,10"
                FontSize="12"
                Foreground="{ThemeResource AppSecondaryTextBrush}">
                <Run x:Name="UpdateTimeLabelRun" />
                <Run x:Name="UpdateTimeText" />
            </TextBlock>
            <CheckBox
                x:Name="DontShowAgainCheckBox"
                IsChecked="False" />
        </StackPanel>
    </Grid>
</ContentDialog>
