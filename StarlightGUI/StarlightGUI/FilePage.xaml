<Page
    x:Class="StarlightGUI.FilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:XamlToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:StarlightGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource WindowBackgroundBrush}"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="PathSegmentButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid Padding="20,10,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource WindowBackgroundBrush}">
                <Border
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="6,6,0,0">
                    <TabView
                        x:Name="FileTabView"
                        AddTabButtonClick="FileTabView_AddTabButtonClick"
                        IsAddTabButtonVisible="True"
                        SelectionChanged="FileTabView_SelectionChanged"
                        TabCloseRequested="FileTabView_TabCloseRequested" />
                </Border>
            </Grid>

            <Border
                Grid.Row="1"
                Padding="8,0"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <CommandBar
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        DefaultLabelPosition="Collapsed"
                        IsDynamicOverflowEnabled="False"
                        OverflowButtonVisibility="Collapsed">
                        <AppBarButton
                            x:Name="BackButton"
                            MaxWidth="40"
                            Click="BackButton_Click">
                            <AppBarButton.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            x:Name="ForwardButton"
                            MaxWidth="40"
                            Click="ForwardButton_Click">
                            <AppBarButton.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72A;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            x:Name="UpButton"
                            MaxWidth="40"
                            Click="UpButton_Click">
                            <AppBarButton.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74A;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            x:Name="RefreshButton"
                            MaxWidth="40"
                            Click="RefreshButton_Click">
                            <AppBarButton.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>

                    <Border
                        Grid.Column="1"
                        Height="34"
                        Padding="4,1,4,1"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <ScrollViewer
                            x:Name="PathSegmentScrollViewer"
                            HorizontalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            VerticalScrollBarVisibility="Hidden"
                            VerticalScrollMode="Disabled"
                            ZoomMode="Disabled">
                            <StackPanel
                                x:Name="PathSegmentPanel"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="4" />
                        </ScrollViewer>
                    </Border>

                    <AutoSuggestBox
                        x:Name="SearchBox"
                        Grid.Column="2"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        essential:AutoSuggestBoxHelper.AcrylicWorkaround="True"
                        PlaceholderText="搜索文件..."
                        QueryIcon="Find"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        SuggestionChosen="SearchBox_SuggestionChosen"
                        TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0">
                <Grid x:Name="HeaderColumnsGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="NameHeaderButton"
                        Grid.Column="0"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        Click="ColumnHeader_Click"
                        Content="文件"
                        CornerRadius="0"
                        Tag="Name" />
                    <Button
                        x:Name="ModifyTimeHeaderButton"
                        Grid.Column="1"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Click="ColumnHeader_Click"
                        Content="修改日期"
                        CornerRadius="0"
                        Tag="ModifyTime" />
                    <Button
                        x:Name="SizeHeaderButton"
                        Grid.Column="2"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        Click="ColumnHeader_Click"
                        Content="大小"
                        CornerRadius="0"
                        Tag="Size" />
                    <ct:GridSplitter
                        Grid.Column="0"
                        Width="9"
                        Margin="0,0,-5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Opacity="0"
                        ResizeBehavior="BasedOnAlignment"
                        ResizeDirection="Columns" />
                    <ct:GridSplitter
                        Grid.Column="1"
                        Width="9"
                        Margin="0,0,-5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Opacity="0"
                        ResizeBehavior="BasedOnAlignment"
                        ResizeDirection="Columns" />
                </Grid>
            </Border>

            <Border
                Grid.Row="3"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5">
                <Grid x:Name="BodyColumnsGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <ProgressRing
                        x:Name="LoadingRing"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="False" />

                    <ListView
                        x:Name="FileListView"
                        Grid.ColumnSpan="3"
                        AllowDrop="True"
                        Background="Transparent"
                        ContainerContentChanging="FileListView_ContainerContentChanging"
                        DoubleTapped="FileListView_DoubleTapped"
                        DragOver="FileListView_DragOver"
                        Drop="FileListView_Drop"
                        IsDoubleTapEnabled="True"
                        IsMultiSelectCheckBoxEnabled="True"
                        ItemContainerStyle="{StaticResource ListViewItemStyle}"
                        RightTapped="FileListView_RightTapped"
                        SelectionMode="Extended">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="FileRowGrid" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <!--  进程图标  -->
                                    <Image
                                        Grid.Column="0"
                                        Width="16"
                                        Height="16"
                                        Margin="16,0,12,0"
                                        VerticalAlignment="Center"
                                        Source="{Binding Icon}" />

                                    <!--  文件名  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="0,-2,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">
                                        <ToolTipService.ToolTip>
                                            <ToolTip
                                                essential:ToolTipHelper.AcrylicWorkaround="True"
                                                Content="{Binding Name}" />
                                        </ToolTipService.ToolTip>
                                    </TextBlock>

                                    <!--  修改日期  -->
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding ModifyTime}" />

                                    <!--  大小  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding Size}" />

                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                    <Border
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>
        <StackPanel
            x:Name="InfoBarPanel"
            Margin="0,10,10,0"
            HorizontalAlignment="Right" />
    </Grid>
</Page>


