<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="StarlightGUI.RunProcessDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:StarlightGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="RunProcessDialogUid"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    PrimaryButtonText=""
    SecondaryButtonText=""
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.TitleTemplate>
        <DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon
                    Margin="0,5,0,0"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="30"
                    Glyph="&#xefda;" />
                <TextBlock VerticalAlignment="Center" Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <Grid>
        <StackPanel Margin="0,0,0,10">
            <TextBlock
                x:Name="RunProcessDescriptionText"
                Margin="0,0,0,20" />
            <TextBox
                x:Name="ProcessPathTextBox"
                Margin="0,0,0,10"
                HorizontalAlignment="Stretch" />

            <ComboBox
                x:Name="PermissionComboBox"
                essential:ComboBoxHelper.AcrylicWorkaround="True"
                ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                SelectedIndex="1"
                Text="">
                <ComboBoxItem x:Name="AdministratorComboBoxItem" Content="Administator" />
                <ComboBoxItem x:Name="TIComboBoxItem" Content="TrustedInstaller" />
            </ComboBox>

            <CheckBox
                x:Name="FullPrivilegesCheckBox"
                IsChecked="False" />
        </StackPanel>
    </Grid>
</ContentDialog>
