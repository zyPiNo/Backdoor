{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build main_dual_new.exe",
            "command": "D:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}\\main_dual_new.c",
                "${workspaceFolder}\\main_dual_new.rc",
                "-o",
                "${workspaceFolder}\\main_dual_new.exe",
                "-mwindows",
                "-ladvapi32",
                "-lwtsapi32",
                "-luserenv"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译 main_dual_new.exe (含嵌入 Sirius.sys 资源)"
        }
    ],
    "version": "2.0.0"
}
